# =============================================================================
# LTX 2.3 Distilled FastAPI Server — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values before starting the server.
#
#   cp .env.example .env
#   # edit .env
#   uvicorn api.main:app --host 0.0.0.0 --port 8000 --workers 1
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — Model Paths
# -----------------------------------------------------------------------------

# Path to the LTX 2.3 distilled model checkpoint (.safetensors)
DISTILLED_CHECKPOINT_PATH=/path/to/ltx-2.3-22b-distilled.safetensors

# Path to the Gemma text encoder root directory
GEMMA_ROOT=/path/to/gemma-3-12b-it-qat-q4_0-unquantized

# Path to the spatial upsampler checkpoint (.safetensors)
SPATIAL_UPSAMPLER_PATH=/path/to/ltx-2.3-spatial-upscaler-x2-1.0.safetensors

# -----------------------------------------------------------------------------
# OPTIONAL — LoRA
# -----------------------------------------------------------------------------

# Path to a LoRA safetensors file (leave blank to disable)
# LORA_PATH=/path/to/lora.safetensors

# LoRA strength (0.0 – 2.0, default 1.0)
# LORA_STRENGTH=1.0

# -----------------------------------------------------------------------------
# Quantization
# Recommended: none  (full BF16 — all models already load in BF16, FP8 only saves ~1-2 GB
#               on the transformer; not worth it on 96 GB VRAM)
# Options:     none | fp8-cast | fp8-scaled-mm
QUANTIZATION=none

# Optional path to pre-computed amax calibration file (fp8-scaled-mm only)
# FP8_AMAX_PATH=/path/to/amax.json

# -----------------------------------------------------------------------------
# Concurrency
# RTX PRO 6000 Blackwell 96 GB — supports up to 4 concurrent generations
# each generation uses ~20-22 GB with FP8 quantization
# -----------------------------------------------------------------------------
MAX_CONCURRENT_JOBS=4

# -----------------------------------------------------------------------------
# Blackwell / CUDA Optimisations
# -----------------------------------------------------------------------------

# Prevent VRAM fragmentation from blocking large allocations (strongly recommended)
CUDA_EXPANDABLE_SEGMENTS=true

# TF32 for matmul and cuDNN (~3x speedup on Blackwell with negligible quality loss)
ENABLE_TF32=true

# torch.compile with max-autotune — first request takes ~60-120 s to compile,
# subsequent requests use compiled CUDA kernels for maximum throughput.
# Disable (false) during development / debugging.
TORCH_COMPILE=false

# -----------------------------------------------------------------------------
# Generation Defaults (overridable per-request)
# -----------------------------------------------------------------------------
DEFAULT_HEIGHT=1024
DEFAULT_WIDTH=1536
DEFAULT_NUM_FRAMES=121
DEFAULT_FRAME_RATE=24.0
DEFAULT_SEED=42

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------

# Directory where generated MP4 files are saved
OUTPUT_DIR=./outputs

# Temporary directory for uploaded conditioning images (auto-cleaned)
TEMP_DIR=./tmp_uploads

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# CORS — comma-separated list of allowed origins, or * for open access
# CORS_ORIGINS=["*"]
